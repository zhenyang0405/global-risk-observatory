OLLAMA_HOST=http://localhost:11434
OBSERVATORY_DB=../data/observatory.db
GEONAMES_PATH=../data/cities15000.txt

# Model ids (Ollama tags)
MODEL_INGEST=gemma4:e4b
MODEL_REASON=gemma4:26b-a4b

# Loops (seconds). Set to 0 to disable a loop.
INGEST_GDELT_INTERVAL=900
INGEST_RSS_INTERVAL=1800
REASON_INTERVAL=600

# Ingestion concurrency
INGEST_CONCURRENCY=4

# API
API_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
